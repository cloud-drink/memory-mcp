{
  "description": "Memory-MCP Automation Hooks",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "node \"$PLUGIN_ROOT/../dist/hooks/handler.js\" SessionStart",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "node \"$PLUGIN_ROOT/../dist/hooks/handler.js\" UserPromptSubmit",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "node \"$PLUGIN_ROOT/../dist/hooks/handler.js\" Stop",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "node \"$PLUGIN_ROOT/../dist/hooks/handler.js\" PostToolUse",
            "timeout": 10
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "node \"$PLUGIN_ROOT/../dist/hooks/handler.js\" PreCompact",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
